{
  "expo": {
    "name": "Frontend",
    "slug": "Frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "frontend-auth",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "salim297",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salim.savenserve"
    },
    "android": {
      "package": "com.salim.saveandserve",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softInputMode": "adjustPan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dd542701-8212-485a-a513-b83d0435823c"
      }
    }
  }
}